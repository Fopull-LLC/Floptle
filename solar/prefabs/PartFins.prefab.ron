[
    (
        name: "PartFins",
        transform: (
            translation: (0.0, 0.0, 0.0),
            rotation: (0.0, 0.0, 0.0, 1.0),
            // A single fin BLADE: thin in Z, tall in Y (along the hull), reaching
            // out in +X. It mounts on a part's flank and, with symmetry, rings the
            // base — a real aero fin, not the centred cluster it used to be.
            scale: (0.7, 0.95, 0.06),
        ),
        matter: Primitive(
            shape: Cube,
            color: (0.55, 0.57, 0.62),
        ),
        scripts: [],
        rigidbody: Some((
            boxed: true,
            mode: Kinematic,
            radius: 0.4,
            height: 1.0,
            // PRE-scale half-extents × node scale → the collider is the blade.
            half_extents: (0.5, 0.5, 0.5),
            restitution: 0.05,
            friction: 0.6,
            gravity: true,
            lock_pos: (false, false, false),
            lock_rot: (false, false, false),
            mass: 0.5,
        )),
    ),
]
