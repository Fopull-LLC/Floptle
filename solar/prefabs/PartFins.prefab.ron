[
    (
        name: "PartFins",
        transform: (
            translation: (0.0, 0.0, 0.0),
            rotation: (0.0, 0.0, 0.0, 1.0),
            scale: (1.0, 1.0, 1.0),
        ),
        // A real SWEPT AERO FIN (procedural mesh, models/parts/fin.glb): the root
        // edge is flush on the hull at x=0, tapering and sweeping back as it reaches
