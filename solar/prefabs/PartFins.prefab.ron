        // symmetry rings them around the base.
        matter: Mesh(
            asset_path: "models/parts/fin.glb",
        ),
        material: Some((
            color: (0.55, 0.57, 0.62),
            shader: Some("shaders/hullPanels.flsl"),
            shader_params: {
                "baseColor": (0.55, 0.57, 0.62, 1.0),
            },
        )),
        scripts: [],
        rigidbody: Some((
            boxed: true,
            mode: Kinematic,
            radius: 0.4,
            height: 1.0,
            half_extents: (0.4, 0.5, 0.08),
            restitution: 0.05,
            friction: 0.6,
            gravity: true,
            lock_pos: (false, false, false),
            lock_rot: (false, false, false),
            mass: 0.5,
        )),
    ),
]
