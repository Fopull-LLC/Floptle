            clips: [
                (
                    start: 0.0,
                    end: 0.34,
                    emit: Some(Rate(
                        rate: 90.0,
                    )),
                ),
                (
                    start: 0.34,
                    end: 0.67,
                    emit: Some(Rate(
                        rate: 90.0,
                    )),
                ),
                (
                    start: 0.67,
                    end: 1.0,
                    emit: Some(Rate(
                        rate: 90.0,
                    )),
                ),
            ],
            automation: [],
            shape: Cone(
                angle: 9.0,
                radius: 0.35,
            ),
            velocity: Range(Vec3((0.0, 16.0, 0.0)), Vec3((0.0, 24.0, 0.0))),
            size: Range(F32(0.9), F32(1.5)),
            rotation: Range(Vec3((0.0, 0.0, 0.0)), Vec3((0.0, 0.0, 360.0))),
            angular_velocity: Range(Vec3((0.0, 0.0, -4.0)), Vec3((0.0, 0.0, 4.0))),
            color: Curve((
